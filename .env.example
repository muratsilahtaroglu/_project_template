# <PROJECT> .env example — copy: cp .env.example .env  (the REAL .env is never committed)
# Every new secret key is added here (with an empty value) + to .gitignore.

# --- Environment ---
ENV=dev   # selects config/<env>.yaml; non-secret params (incl. log_level) live there

# --- Database (example) ---
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=__CHANGE_ME__

# --- External services (example) ---
# LLM_BASE_URL=
# LLM_MODEL=
# LLM_API_KEY=

# --- Auth (example) ---
JWT_SECRET=__CHANGE_ME__

# --- Ports ---
API_PORT=
